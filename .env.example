# Database
DATABASE_URL=postgres://gh:password@db:5432/github_roles

# Discord OAuth (for user verification)
SESSION_SECRET=your-random-secret-here

# GitHub OAuth App (for user account linking)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Personal Access Token (for server-side repo data fetching, 5000 req/hr)
GITHUB_TOKEN=

# Server
BASE_URL=https://github-roles.example.com/github-contributor-role
LISTEN_ADDR=0.0.0.0:8080

# Auth Gateway (centralized Discord OAuth + guild membership source of truth).
# In prod this can be left unset (it will derive from BASE_URL's origin).
# In local dev set it to the gateway's local listener so the call doesn't
# go back through Cloudflare and hit a different gateway instance.
AUTH_GATEWAY_URL=
# Shared secret for plugin → gateway /auth/internal/* calls.
# Must match INTERNAL_API_KEY on the Auth Gateway exactly.
INTERNAL_API_KEY=your_random_internal_api_key

# Optional tuning
GITHUB_MAX_REQUESTS_PER_HOUR=4500
RUST_LOG=github_roles=info
